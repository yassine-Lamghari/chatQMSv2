# ─── Sécurité JWT ───────────────────────────────────────────────────────────
# OBLIGATOIRE en production : générer avec: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=change-me-generate-a-long-random-secret-key-here
JWT_EXPIRE_MINUTES=480

# ─── Chiffrement des clés API ────────────────────────────────────────────────
# Générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=generate-a-fernet-key-here

# ─── LLM Providers ──────────────────────────────────────────────────────────
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GEMINI_CHAT_MODEL=gemini-2.0-flash
DEEPSEEK_CHAT_MODEL=deepseek-chat

# ─── Ollama (local) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# ─── RAG / Chroma ────────────────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHROMA_PERSIST_DIR=./chroma_db

# ─── Frontend URL (CORS) ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
